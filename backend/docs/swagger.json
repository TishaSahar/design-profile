        "/requests": {
            "post": {
                "description": "Submits a new client project request with optional attachments (up to 10 photos or 1 PDF).",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "requests"
                ],
                "summary": "Submit project request",
                "parameters": [
                    {
                        "type": "string",
                        "description": "First name",
                        "name": "first_name",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Last name",
                        "name": "last_name",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Contact info (phone/email/telegram)",
                        "name": "contact",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Project description",
                        "name": "description",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "boolean",
                        "description": "Consent to personal data processing",
                        "name": "consented",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "file",
